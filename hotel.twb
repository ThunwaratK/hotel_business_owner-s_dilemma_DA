    <worksheet name='Sheet 20'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Revenue Loss</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='bookings' name='federated.1ph4wwk16hkls813f9n960rv1y0s' />
          </datasources>
          <datasource-dependencies datasource='federated.1ph4wwk16hkls813f9n960rv1y0s'>
            <column datatype='real' name='[ADR]' role='measure' type='quantitative' />
            <column caption='Segment' datatype='string' name='[Calculation_1399467269005313]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [rate_name] = &quot;Promotional Rate&quot; &#13;&#10;AND ([channel_id] = &quot;CH_OTA_BKG&quot; OR [channel_id] = &quot;CH_OTA_EXP&quot;) THEN &quot;Promo + OTA&quot;&#13;&#10;&#13;&#10;ELSEIF [rate_name] = &quot;Promotional Rate&quot; THEN &quot;Promo Only&quot;&#13;&#10;&#13;&#10;ELSEIF ([channel_id] = &quot;CH_OTA_BKG&quot; OR [channel_id] = &quot;CH_OTA_EXP&quot;) THEN &quot;OTA Only&quot;&#13;&#10;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
            </column>
            <column caption='ADR Gap' datatype='real' name='[Calculation_1399467284508675]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([ADR]) - AVG([net_ADR])' />
            </column>
            <column caption='Channel Id' datatype='string' name='[channel_id]' role='dimension' type='nominal' />
            <column caption='net ADR' datatype='real' name='[net_ADR]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1399467269005313]' derivation='None' name='[none:Calculation_1399467269005313:nk]' pivot='key' type='nominal' />
            <column caption='Rate Name' datatype='string' name='[rate_name]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1399467284508675]' derivation='User' name='[usr:Calculation_1399467284508675:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1ph4wwk16hkls813f9n960rv1y0s].[none:Calculation_1399467269005313:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:Calculation_1399467269005313:nk]' member='&quot;OTA Only&quot;' />
              <groupfilter function='member' level='[none:Calculation_1399467269005313:nk]' member='&quot;Promo + OTA&quot;' />
            </groupfilter>
          </filter>
          <slices>
            <column>[federated.1ph4wwk16hkls813f9n960rv1y0s].[none:Calculation_1399467269005313:nk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane id='1' selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <style>
              <style-rule element='mark'>
                <format attr='mark-color' value='#e15759' />
              </style-rule>
            </style>
          </pane>
        </panes>
