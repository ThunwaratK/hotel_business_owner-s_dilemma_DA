    <worksheet name='Net-Net Margin'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Question:</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> After ALL costs, what percentage do we keep?</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='bookings' name='federated.1ph4wwk16hkls813f9n960rv1y0s' />
          </datasources>
          <datasource-dependencies datasource='federated.1ph4wwk16hkls813f9n960rv1y0s'>
            <column caption='Total Acquisition Cost' datatype='real' name='[Calculation_0512435954438144]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ZN(SUM([true_commission_cost])) + ZN(SUM([cost_amount]))' />
            </column>
            <column caption='Net-Net Margin %' datatype='real' name='[Calculation_0512435954851843]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([true_gross_room_revenue]) - [Calculation_0512435954438144]) / SUM([true_gross_room_revenue])' />
            </column>
            <column caption='Channel Name' datatype='string' name='[channel_name]' role='dimension' type='nominal' />
            <column caption='Cost Amount' datatype='integer' name='[cost_amount]' role='measure' type='quantitative' />
            <column-instance column='[channel_name]' derivation='None' name='[none:channel_name:nk]' pivot='key' type='nominal' />
            <column caption='True Commission Cost' datatype='real' name='[true_commission_cost]' role='measure' type='quantitative' />
            <column caption='True Gross Room Revenue' datatype='real' name='[true_gross_room_revenue]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0512435954851843]' derivation='User' name='[usr:Calculation_0512435954851843:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <computed-sort column='[federated.1ph4wwk16hkls813f9n960rv1y0s].[none:channel_name:nk]' direction='DESC' using='[federated.1ph4wwk16hkls813f9n960rv1y0s].[usr:Calculation_0512435954851843:qk]' />
