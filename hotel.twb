      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1ph4wwk16hkls813f9n960rv1y0s].[avg:ADR:qk]&quot;' value='ADR' />
          <alias key='&quot;[federated.1ph4wwk16hkls813f9n960rv1y0s].[avg:net_ADR:qk]&quot;' value='net ADR' />
          <alias key='&quot;[federated.1ph4wwk16hkls813f9n960rv1y0s].[sum:true_gross_room_revenue:qk]&quot;' value='Gross Room Revenue' />
          <alias key='&quot;[federated.1ph4wwk16hkls813f9n960rv1y0s].[sum:true_net_room_revenue:qk]&quot;' value='Net Room Revenue' />
        </aliases>
      </column>
      <column datatype='real' name='[ADR]' role='measure' type='quantitative' />
      <column caption='Total Acquisition Cost' datatype='real' name='[Calculation_0512435954438144]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN(SUM([true_commission_cost])) + ZN(SUM([cost_amount]))&#13;&#10;//The total pool of dollars your hotel &#13;&#10;//spent to acquire business.' />
      </column>
      <column caption='CPA (Cost per Booking)' datatype='real' name='[Calculation_0512435954614273]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0512435954438144] / COUNTD([booking_id])&#13;&#10;//Take all the money we spent to get guests, &#13;&#10;//and divide it by the number of unique reservations &#13;&#10;//we received' />
      </column>
      <column caption='Net-Net Margin %' datatype='real' name='[Calculation_0512435954851843]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([true_gross_room_revenue]) - [Calculation_0512435954438144]) / SUM([true_gross_room_revenue])' />
      </column>
      <column caption='Total After Ads' datatype='real' name='[Calculation_1399467258310656]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([true_gross_room_revenue]) - SUM([cost_amount])&#13;&#10;//ค่า Gross - ค่า Ads' />
      </column>
      <column caption='Segment' datatype='string' name='[Calculation_1399467269005313]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [rate_name] = &quot;Promotional Rate&quot; &#13;&#10;AND ([channel_id] = &quot;CH_OTA_BKG&quot; OR [channel_id] = &quot;CH_OTA_EXP&quot;) THEN &quot;Promo + OTA&quot;&#13;&#10;&#13;&#10;ELSEIF [rate_name] = &quot;Promotional Rate&quot; THEN &quot;Promo Only&quot;&#13;&#10;&#13;&#10;ELSEIF ([channel_id] = &quot;CH_OTA_BKG&quot; OR [channel_id] = &quot;CH_OTA_EXP&quot;) THEN &quot;OTA Only&quot;&#13;&#10;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Number of Records' datatype='integer' name='[Calculation_1399467274801154]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([booking_id] )' />
      </column>
      <column caption='ADR Gap' datatype='real' name='[Calculation_1399467284508675]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([ADR]) - AVG([net_ADR])' />
      </column>
      <column caption='Discount' datatype='real' name='[Calculation_1399467288829958]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [rate_code_id] != &quot;PROMO&quot; THEN [ADR] END&#13;&#10;)&#13;&#10;-&#13;&#10;AVG(&#13;&#10;IF [rate_code_id] = &quot;PROMO&quot; THEN [ADR] END&#13;&#10;)' />
      </column>
      <column caption='COA%' datatype='real' name='[Calculation_1454442485334017]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM([true_commission_cost]) + ZN(SUM([cost_amount]))&#13;&#10;)&#13;&#10;/&#13;&#10;SUM([true_gross_room_revenue])' />
      </column>
