    <worksheet name='Net Revenue Breakdown'>
      <table>
        <view>
          <datasources>
            <datasource caption='bookings' name='federated.1ph4wwk16hkls813f9n960rv1y0s' />
          </datasources>
          <datasource-dependencies datasource='federated.1ph4wwk16hkls813f9n960rv1y0s'>
            <column caption='Segment' datatype='string' name='[Calculation_1399467269005313]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [rate_name] = &quot;Promotional Rate&quot; &#13;&#10;AND ([channel_id] = &quot;CH_OTA_BKG&quot; OR [channel_id] = &quot;CH_OTA_EXP&quot;) THEN &quot;Promo + OTA&quot;&#13;&#10;&#13;&#10;ELSEIF [rate_name] = &quot;Promotional Rate&quot; THEN &quot;Promo Only&quot;&#13;&#10;&#13;&#10;ELSEIF ([channel_id] = &quot;CH_OTA_BKG&quot; OR [channel_id] = &quot;CH_OTA_EXP&quot;) THEN &quot;OTA Only&quot;&#13;&#10;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
            </column>
            <column caption='Channel Id' datatype='string' name='[channel_id]' role='dimension' type='nominal' />
            <column caption='Commission Cost' datatype='real' name='[commission_cost]' role='measure' type='quantitative' />
            <column caption='Cost Amount' datatype='integer' name='[cost_amount]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1399467269005313]' derivation='None' name='[none:Calculation_1399467269005313:nk]' pivot='key' type='nominal' />
            <column caption='Rate Name' datatype='string' name='[rate_name]' role='dimension' type='nominal' />
            <column-instance column='[commission_cost]' derivation='Sum' name='[sum:commission_cost:qk]' pivot='key' type='quantitative' />
            <column-instance column='[cost_amount]' derivation='Sum' name='[sum:cost_amount:qk]' pivot='key' type='quantitative' />
            <column-instance column='[true_gross_room_revenue]' derivation='Sum' name='[sum:true_gross_room_revenue:qk]' pivot='key' type='quantitative' />
            <column-instance column='[true_net_room_revenue]' derivation='Sum' name='[sum:true_net_room_revenue:qk]' pivot='key' type='quantitative' />
            <column caption='True Gross Room Revenue' datatype='real' name='[true_gross_room_revenue]' role='measure' type='quantitative' />
            <column caption='True Net Room Revenue' datatype='real' name='[true_net_room_revenue]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.1ph4wwk16hkls813f9n960rv1y0s].[none:Calculation_1399467269005313:nk]' direction='ASC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.1ph4wwk16hkls813f9n960rv1y0s].[sum:true_gross_room_revenue:qk]' shelf='columns' />
          </shelf-sorts>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <color column='[federated.1ph4wwk16hkls813f9n960rv1y0s].[sum:commission_cost:qk]' />
              <lod column='[federated.1ph4wwk16hkls813f9n960rv1y0s].[sum:cost_amount:qk]' />
              <lod column='[federated.1ph4wwk16hkls813f9n960rv1y0s].[sum:true_net_room_revenue:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[federated.1ph4wwk16hkls813f9n960rv1y0s].[sum:true_gross_room_revenue:qk]</rows>
        <cols>[federated.1ph4wwk16hkls813f9n960rv1y0s].[none:Calculation_1399467269005313:nk]</cols>
      </table>
