      <table>
        <view>
          <datasources>
            <datasource caption='bookings' name='federated.1ph4wwk16hkls813f9n960rv1y0s' />
          </datasources>
          <datasource-dependencies datasource='federated.1ph4wwk16hkls813f9n960rv1y0s'>
            <column caption='Total Acquisition Cost' datatype='real' name='[Calculation_0512435954438144]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ZN(SUM([true_commission_cost])) + ZN(SUM([cost_amount]))' />
            </column>
            <column caption='Net-Net Margin %' datatype='real' name='[Calculation_0512435954851843]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([true_gross_room_revenue]) - [Calculation_0512435954438144]) / SUM([true_gross_room_revenue])' />
            </column>
            <column caption='Channel Name' datatype='string' name='[channel_name]' role='dimension' type='nominal' />
            <column caption='Cost Amount' datatype='integer' name='[cost_amount]' role='measure' type='quantitative' />
            <column-instance column='[channel_name]' derivation='None' name='[none:channel_name:nk]' pivot='key' type='nominal' />
